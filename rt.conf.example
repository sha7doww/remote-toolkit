# Remote Toolkit Configuration
#
# Default profile:  cp rt.conf.example rt.conf
# Named profile:    cp rt.conf.example rt.conf.<name>
#                   e.g., cp rt.conf.example rt.conf.hpc

# REQUIRED: Remote host (user@hostname or ~/.ssh/config alias)
REMOTE_HOST="user@example.com"

# REQUIRED: Remote directory to sync
REMOTE_DIR="/home/user/project"

# Optional — SSH
# SSH_PORT=22
# SSH_KEY="$HOME/.ssh/id_ed25519"
# NOTE: For non-default port/key, also add a Host entry to ~/.ssh/config
# so Mutagen sync uses the same SSH parameters as `rt exec`.

# Optional — Mutagen sync
#   default profile → ~/work
#   named profile   → ~/work/<name>
# LOCAL_DIR="$HOME/work"
# MUTAGEN_SYNC_MODE="two-way-resolved"   # two-way-safe|two-way-resolved|one-way-safe|one-way-replica
# MUTAGEN_IGNORE_VCS=1                   # 1 = pass --ignore-vcs (default), 0 = sync .git
# MUTAGEN_IGNORE=(                       # bash array; appended to defaults
#   "data/"
#   "*.bin"
# )

# Optional — Slurm (HPC clusters with login node + sbatch)
# SLURM_ENABLED=0                        # 1 enables `rt slurm submit/queue/cancel/logs`
# SLURM_LOG_DIR="$REMOTE_DIR"            # where slurm-<jobid>.out lands
