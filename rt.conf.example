# Remote Toolkit Configuration
#
# Default profile:  cp rt.conf.example rt.conf
# Named profile:    cp rt.conf.example rt.conf.<name>
#                   e.g., cp rt.conf.example rt.conf.gpu1

# REQUIRED: Remote host (user@hostname or SSH config alias)
REMOTE_HOST="user@example.com"

# REQUIRED: Remote directory to mount
REMOTE_DIR="/home/user/project"

# Optional: Local mount point
#   default profile → ~/remote
#   named profile   → ~/remote/<name>
# LOCAL_MOUNT="$HOME/remote"

# Optional: SSH key path (default: use SSH agent)
# SSH_KEY="$HOME/.ssh/id_ed25519"

# Optional: SSH port (default: 22)
# SSH_PORT=22
