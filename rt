#!/usr/bin/env bash
set -euo pipefail

# ── Paths (defaults, may be overridden by profile) ────────────────
RT_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RT_HOME="${RT_HOME:-${XDG_CONFIG_HOME:-$HOME/.config}/remote-toolkit}"
RT_PROFILE="default"
RT_CONF=""
RT_STATE_DIR=""
RT_SESSION_PREFIX=""

# ── Colors & output helpers ────────────────────────────────────────
_color() { [[ -t 2 ]] && printf '\e[%sm' "$1" >&2 || true; }
_reset() { _color 0; }
info()  { _color 32; printf ':: %s\n' "$*" >&2; _reset; }
warn()  { _color 33; printf '!! %s\n' "$*" >&2; _reset; }
die()   { _color 31; printf 'ERROR: %s\n' "$*" >&2; _reset; exit 1; }

# ── Platform detection ────────────────────────────────────────────
RT_OS="$(uname -s)"   # "Linux" or "Darwin"

_install_hint() {
  if [[ "$RT_OS" == "Darwin" ]]; then
    case "$1" in
      mutagen) echo "brew install mutagen-io/mutagen/mutagen" ;;
      sshpass) echo "brew install esolitos/ipa/sshpass" ;;
      *)       echo "brew install $1" ;;
    esac
  else
    case "$1" in
      mutagen) echo "see https://mutagen.io/documentation/introduction/installation" ;;
      *)       echo "sudo apt install $1" ;;
    esac
  fi
}

# ── Profile-aware paths ───────────────────────────────────────────
_init_profile() {
  if [[ "$RT_PROFILE" == "default" ]]; then
    RT_CONF="${RT_HOME}/rt.conf"
  else
    RT_CONF="${RT_HOME}/rt.conf.${RT_PROFILE}"
  fi
  RT_STATE_DIR="${RT_HOME}/.rt/${RT_PROFILE}"
  RT_SESSION_PREFIX="rt_${RT_PROFILE}_bg_"
}

# ── Mutagen helpers ────────────────────────────────────────────────
_mutagen_check() {
  command -v mutagen >/dev/null 2>&1 \
    || die "mutagen not found. Ask the user to install: $(_install_hint mutagen)"
}

_mutagen_daemon_ensure() {
  # Idempotent: returns success if already running.
  mutagen daemon start >/dev/null 2>&1 || true
}

_sync_session_name() {
  echo "rt-${RT_PROFILE}"
}

_has_sync() {
  local p="${1:-$RT_PROFILE}"
  mutagen sync list --label-selector "rt-profile=${p}" 2>/dev/null \
    | grep -q '^Identifier:'
}

_sync_status() {
  local p="${1:-$RT_PROFILE}"
  local out
  out=$(mutagen sync list --label-selector "rt-profile=${p}" 2>/dev/null) || { echo none; return; }
  if ! echo "$out" | grep -q '^Identifier:'; then
    echo none
    return
  fi
  if echo "$out" | grep -q 'Status:.*Paused'; then
    echo paused
  elif echo "$out" | grep -q 'Connected: No'; then
    echo offline
  else
    echo active
  fi
}

_sync_flush() {
  local p="${1:-$RT_PROFILE}"
  mutagen sync flush --label-selector "rt-profile=${p}" >/dev/null 2>&1
}

_sync_terminate() {
  local p="${1:-$RT_PROFILE}"
  mutagen sync terminate --label-selector "rt-profile=${p}" >/dev/null 2>&1 || true
}

_sync_create() {
  local session_name
  session_name=$(_sync_session_name)
  local mutagen_url="${REMOTE_HOST}:${REMOTE_DIR}"

  local sync_mode="${MUTAGEN_SYNC_MODE:-two-way-resolved}"

  local args=(
    --name="${session_name}"
    --label="rt-profile=${RT_PROFILE}"
    --mode="${sync_mode}"
  )

  if [[ "${MUTAGEN_IGNORE_VCS:-1}" == "1" ]]; then
    args+=(--ignore-vcs)
  fi

  local default_ignores=(
    "__pycache__/" "*.pyc" ".venv/" "venv/" "node_modules/"
    "wandb/" "outputs/" "checkpoints/" ".ipynb_checkpoints/"
    ".DS_Store" "*.swp"
  )
  local pat
  for pat in "${default_ignores[@]}"; do
    args+=("--ignore=${pat}")
  done

  if [[ -n "${MUTAGEN_IGNORE+x}" ]]; then
    for pat in "${MUTAGEN_IGNORE[@]}"; do
      args+=("--ignore=${pat}")
    done
  fi

  mutagen sync create "${args[@]}" "${LOCAL_DIR}" "${mutagen_url}"
}

# ── Config ─────────────────────────────────────────────────────────
load_config() {
  [[ -f "$RT_CONF" ]] || die "Config not found: $RT_CONF
  Run 'rt init' to create from template, or create manually in $RT_HOME/"
  # shellcheck source=/dev/null
  . "$RT_CONF"
  [[ -n "${REMOTE_HOST:-}" ]] || die "REMOTE_HOST not set in $RT_CONF"
  [[ -n "${REMOTE_DIR:-}" ]]  || die "REMOTE_DIR not set in $RT_CONF"

  # Default local replica dir: ~/work for default profile, ~/work/<name> for named
  if [[ "$RT_PROFILE" == "default" ]]; then
    LOCAL_DIR="${LOCAL_DIR:-$HOME/work}"
  else
    LOCAL_DIR="${LOCAL_DIR:-$HOME/work/${RT_PROFILE}}"
  fi
  SSH_PORT="${SSH_PORT:-22}"
  SSH_KEY="${SSH_KEY:-}"
  SLURM_ENABLED="${SLURM_ENABLED:-0}"
  SLURM_LOG_DIR="${SLURM_LOG_DIR:-$REMOTE_DIR}"

  # Build shared SSH options array (used by direct _ssh calls; Mutagen uses ~/.ssh/config)
  SSH_OPTS=(
    -o ConnectTimeout=10
    -o BatchMode=yes
    -o ServerAliveInterval=30
    -o ServerAliveCountMax=3
    -p "$SSH_PORT"
  )
  if [[ -n "$SSH_KEY" ]]; then SSH_OPTS+=(-i "$SSH_KEY"); fi
}

# ── State helpers ──────────────────────────────────────────────────
save_state() {
  mkdir -p "$RT_STATE_DIR"
  printf '%s' "$REMOTE_HOST"           > "$RT_STATE_DIR/host"
  printf '%s' "$LOCAL_DIR"             > "$RT_STATE_DIR/local_dir"
  printf '%s' "$REMOTE_DIR"            > "$RT_STATE_DIR/remote_dir"
  printf '%s' "$RT_PROFILE"            > "$RT_STATE_DIR/profile"
  printf '%s' "$(_sync_session_name)"  > "$RT_STATE_DIR/sync_session"
}

clear_state() {
  rm -rf "$RT_STATE_DIR"
}

_ssh() {
  ssh "${SSH_OPTS[@]}" "$REMOTE_HOST" "$@"
}

_ssh_test() {
  _ssh "echo ok" >/dev/null 2>&1
}

# ── Subcommands ────────────────────────────────────────────────────

cmd_check() {
  local ok=true
  printf 'Checking dependencies ...\n\n'

  # Format: command|package|missing_note|alt_command
  local deps=(
    "ssh|ssh||"
    "tmux|tmux||"
    "mutagen|mutagen||"
    "sshpass|sshpass|needed for rt setup-key --password|"
  )

  for entry in "${deps[@]}"; do
    IFS='|' read -r cmd pkg note alt <<< "$entry"
    if command -v "$cmd" >/dev/null 2>&1; then
      info "$cmd — OK ($(command -v "$cmd"))"
    elif [[ -n "$alt" ]] && command -v "$alt" >/dev/null 2>&1; then
      info "$cmd — OK ($(command -v "$alt"))"
    else
      local label="MISSING"
      [[ -n "$note" ]] && label="MISSING ($note)"
      warn "$cmd — $label"
      [[ -n "$pkg" ]] && printf '  Install: %s\n' "$(_install_hint "$pkg")"
      ok=false
    fi
  done

  printf '\n'
  if [[ "$ok" == true ]]; then
    info "All dependencies satisfied."
  else
    warn "Some dependencies are missing. Ask the user to run the install commands above."
  fi
  [[ "$ok" == true ]]
}

cmd_init() {
  mkdir -p "$RT_HOME"

  if [[ -f "$RT_CONF" ]]; then
    info "Config already exists: $RT_CONF"
  else
    if [[ -f "$RT_SCRIPT_DIR/rt.conf.example" ]]; then
      cp "$RT_SCRIPT_DIR/rt.conf.example" "$RT_CONF"
      info "Created $RT_CONF from template."
    else
      cat > "$RT_CONF" <<'TMPL'
REMOTE_HOST="user@example.com"
REMOTE_DIR="/home/user/project"
# SSH_PORT=22
# SSH_KEY="$HOME/.ssh/id_ed25519"
# LOCAL_DIR="$HOME/work"
# MUTAGEN_SYNC_MODE="two-way-resolved"
# MUTAGEN_IGNORE_VCS=1
# MUTAGEN_IGNORE=("data/")
# SLURM_ENABLED=0
# SLURM_LOG_DIR="$REMOTE_DIR"
TMPL
      info "Created $RT_CONF with defaults."
    fi
    info "Edit $RT_CONF with your server details."
  fi

  info "Config directory: $RT_HOME"
  info "Next: edit config, then run 'rt connect'"
}

cmd_setup_key() {
  load_config

  # Parse flags
  local password=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --password)   password="$2"; shift 2 ;;
      --password=*) password="${1#--password=}"; shift ;;
      *)            die "Usage: rt setup-key [--password PASSWORD]" ;;
    esac
  done

  # Determine which key to copy
  local key_file="${SSH_KEY:-}"
  if [[ -z "$key_file" ]]; then
    for k in "$HOME/.ssh/id_ed25519" "$HOME/.ssh/id_rsa"; do
      if [[ -f "$k" ]]; then key_file="$k"; break; fi
    done
  fi
  [[ -n "$key_file" && -f "$key_file" ]] || die "No SSH key found. Generate one: ssh-keygen -t ed25519"
  [[ -f "${key_file}.pub" ]] || die "Public key not found: ${key_file}.pub"

  info "[$RT_PROFILE] Copying ${key_file}.pub → $REMOTE_HOST (port $SSH_PORT)"

  if [[ -n "$password" ]]; then
    # Non-interactive: use sshpass
    command -v sshpass >/dev/null 2>&1 \
      || die "sshpass not found. Ask the user to install: $(_install_hint sshpass)"
    SSHPASS="$password" sshpass -e ssh-copy-id \
      -o StrictHostKeyChecking=accept-new \
      -i "$key_file" -p "$SSH_PORT" "$REMOTE_HOST"
  else
    # Interactive: prompt for password
    info "You will be prompted for the remote password (one time only)."
    ssh-copy-id -i "$key_file" -p "$SSH_PORT" "$REMOTE_HOST"
  fi

  # Verify key auth works
  info "Verifying key authentication ..."
  if _ssh_test; then
    info "Key auth works! You can now use: rt connect"
  else
    die "Key was copied but verification failed. Check server sshd_config."
  fi
}

cmd_connect() {
  load_config
  _mutagen_check
  _mutagen_daemon_ensure

  # Idempotent: sync session already exists → just flush and exit
  if _has_sync; then
    info "[$RT_PROFILE] Already connected to $REMOTE_HOST (flushing pending changes)"
    _sync_flush || warn "Sync flush had issues; check 'rt status' / 'mutagen sync list'."
    cmd_status
    return 0
  fi

  # Test SSH connectivity
  info "[$RT_PROFILE] Testing SSH connection to $REMOTE_HOST ..."
  if ! _ssh_test; then
    die "Cannot reach $REMOTE_HOST via SSH. If using password auth, run 'rt setup-key' first."
  fi

  # Verify remote directory exists
  if ! _ssh "test -d '$REMOTE_DIR'"; then
    die "Remote directory does not exist: $REMOTE_DIR"
  fi

  # Warn on non-default ssh params (Mutagen uses ~/.ssh/config, not SSH_OPTS)
  if [[ "$SSH_PORT" != "22" ]] || [[ -n "$SSH_KEY" ]]; then
    warn "Non-default SSH_PORT or SSH_KEY detected."
    warn "Mutagen uses ~/.ssh/config for SSH parameters. Add an entry like:"
    warn "  Host ${REMOTE_HOST#*@}"
    [[ "$SSH_PORT" != "22" ]] && warn "    Port ${SSH_PORT}"
    [[ -n "$SSH_KEY" ]]       && warn "    IdentityFile ${SSH_KEY}"
    warn "Otherwise sync may fail with 'connection refused' or auth errors."
  fi

  # Create local replica directory
  mkdir -p "$LOCAL_DIR"

  # Create Mutagen sync session
  info "[$RT_PROFILE] Starting sync: $LOCAL_DIR ⇄ $REMOTE_HOST:$REMOTE_DIR ..."
  if ! _sync_create; then
    die "Mutagen sync create failed. Check 'mutagen sync list' for diagnostics."
  fi

  save_state
  info "[$RT_PROFILE] Connected!"
  info "  Local:    $LOCAL_DIR (auto-syncs in background)"
  info "  Remote:   $REMOTE_HOST:$REMOTE_DIR"
  info "  Session:  $(_sync_session_name)"
  info "  Status:   rt -p $RT_PROFILE status"
}

cmd_disconnect() {
  load_config

  # Best-effort: kill remote background sessions for this profile (only if SSH reachable)
  if _ssh_test; then
    info "[$RT_PROFILE] Cleaning up remote background jobs ..."
    _ssh \
      "tmux list-sessions -F '#{session_name}' 2>/dev/null \
       | grep '^${RT_SESSION_PREFIX}' \
       | xargs -I{} tmux kill-session -t {} 2>/dev/null" \
      2>/dev/null || true
  fi

  if _has_sync; then
    info "[$RT_PROFILE] Terminating sync session $(_sync_session_name) ..."
    _sync_terminate
  else
    info "[$RT_PROFILE] No active sync session."
  fi

  clear_state
  info "[$RT_PROFILE] Disconnected. Local replica preserved at $LOCAL_DIR"
}

cmd_exec() {
  load_config

  # Parse flags
  local bg=false
  local name=""
  local no_flush=false
  local cmd_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --bg)        bg=true; shift ;;
      --name)      name="$2"; shift 2 ;;
      --name=*)    name="${1#--name=}"; shift ;;
      --no-flush)  no_flush=true; shift ;;
      --)          shift; cmd_args+=("$@"); break ;;
      -*)          die "Unknown flag: $1" ;;
      *)           cmd_args+=("$@"); break ;;
    esac
  done

  [[ ${#cmd_args[@]} -gt 0 ]] || die "Usage: rt exec [--bg] [--name NAME] [--no-flush] <command>"

  # Need SSH; sync state is independent
  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST. Run 'rt connect' first."

  # Auto-flush sync so the remote sees latest edits before exec
  if [[ "$no_flush" == false ]] && _has_sync; then
    _sync_flush || warn "Sync flush had issues; continuing anyway. Use --no-flush to suppress."
  fi

  local command="${cmd_args[*]}"
  if [[ "$bg" == true ]]; then
    _exec_bg "$command" "$name"
  else
    _exec_sync "$command"
  fi
}

_exec_sync() {
  local command="$1"
  _ssh "cd '${REMOTE_DIR}' && ${command}"
}

_exec_bg() {
  local command="$1"
  local name="$2"

  # Check remote tmux
  if ! _ssh "command -v tmux" >/dev/null 2>&1; then
    die "tmux not found on remote server. Install tmux on $REMOTE_HOST for background execution."
  fi

  # Generate session name
  local session
  if [[ -n "$name" ]]; then
    session="${RT_SESSION_PREFIX}${name}"
  else
    session="${RT_SESSION_PREFIX}$(date +%s)_$$"
  fi

  # Create remote log directory
  _ssh "mkdir -p ~/.rt_logs"

  # Start tmux session on remote
  local log_file="~/.rt_logs/${session}.log"
  _ssh \
    "tmux new-session -d -s '${session}' -x 200 -y 50 \
      \"cd '${REMOTE_DIR}' && { ${command}; } 2>&1 | tee ${log_file}; echo \\\"EXIT_CODE=\\\$?\\\" >> ${log_file}\""

  info "[$RT_PROFILE] Background job started: $session"
  info "  Check output: rt -p $RT_PROFILE logs $session"
}

cmd_logs() {
  load_config

  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST. Run 'rt connect' first."

  local job_id="${1:-}"
  local follow=false
  [[ "${2:-}" == "--follow" || "${2:-}" == "-f" ]] && follow=true

  if [[ -z "$job_id" ]]; then
    _logs_list
  elif [[ "$follow" == true ]]; then
    _ssh "tail -f ~/.rt_logs/${job_id}.log" 2>/dev/null \
      || die "Log not found: $job_id"
  else
    _logs_show "$job_id"
  fi
}

_logs_list() {
  info "[$RT_PROFILE] Background jobs on $REMOTE_HOST:"
  printf '\n'

  # Get running tmux sessions
  local running
  running=$(_ssh \
    "tmux list-sessions -F '#{session_name}' 2>/dev/null | grep '^${RT_SESSION_PREFIX}'" 2>&1) || {
    if [[ "$running" == *"Connection"* || "$running" == *"resolve"* || "$running" == *"No route"* ]]; then
      warn "Cannot reach $REMOTE_HOST"
      return 1
    fi
    running=""
  }

  # Get all log files
  local logs
  logs=$(_ssh \
    "ls -1 ~/.rt_logs/${RT_SESSION_PREFIX}*.log 2>/dev/null | xargs -I{} basename {} .log" 2>/dev/null) || true

  if [[ -z "$running" && -z "$logs" ]]; then
    printf '  (none)\n'
    return 0
  fi

  # Print running sessions
  while IFS= read -r s; do
    [[ -n "$s" ]] && printf '  %-40s  [RUNNING]\n' "$s"
  done <<< "$running"

  # Print finished (has log but no tmux session)
  while IFS= read -r s; do
    [[ -n "$s" ]] || continue
    if ! echo "$running" | grep -qx "$s"; then
      local exit_code
      exit_code=$(_ssh \
        "tail -1 ~/.rt_logs/${s}.log 2>/dev/null | sed -n 's/.*EXIT_CODE=\([0-9][0-9]*\).*/\1/p'" 2>/dev/null) || exit_code="?"
      if [[ "$exit_code" == "0" ]]; then
        printf '  %-40s  [DONE]\n' "$s"
      else
        printf '  %-40s  [EXITED: %s]\n' "$s" "$exit_code"
      fi
    fi
  done <<< "$logs"
}

_logs_show() {
  local job_id="$1"
  _ssh "cat ~/.rt_logs/${job_id}.log" 2>/dev/null \
    || die "Log not found: $job_id"
}

cmd_status() {
  # If --all flag, show all profiles
  if [[ "${1:-}" == "--all" || "${1:-}" == "-a" ]]; then
    _status_all
    return
  fi

  load_config

  printf '\n'
  local sync_state
  sync_state=$(_sync_status)

  if [[ "$sync_state" != "none" ]]; then
    local host="${REMOTE_HOST}"
    local rdir="${REMOTE_DIR}"
    local local_dir="${LOCAL_DIR}"

    [[ -f "$RT_STATE_DIR/host" ]]       && host=$(cat "$RT_STATE_DIR/host")
    [[ -f "$RT_STATE_DIR/remote_dir" ]] && rdir=$(cat "$RT_STATE_DIR/remote_dir")
    [[ -f "$RT_STATE_DIR/local_dir" ]]  && local_dir=$(cat "$RT_STATE_DIR/local_dir")

    local ssh_ok="reachable"
    _ssh_test || ssh_ok="UNREACHABLE"

    local bg_running=0
    if [[ "$ssh_ok" == "reachable" ]]; then
      bg_running=$(_ssh \
        "tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -c '^${RT_SESSION_PREFIX}'" 2>/dev/null) || bg_running=0
    fi

    printf '  Profile:     %s\n' "$RT_PROFILE"
    printf '  Sync:        %s\n' "$sync_state"
    printf '  SSH:         %s\n' "$ssh_ok"
    printf '  Remote host: %s\n' "$host"
    printf '  Remote dir:  %s\n' "$rdir"
    printf '  Local dir:   %s\n' "$local_dir"
    [[ "${SLURM_ENABLED:-0}" == "1" ]] && printf '  Slurm:       enabled\n'
    if [[ $bg_running -gt 0 ]]; then printf '  Background:  %d running\n' "$bg_running"; fi
  else
    printf '  Profile:     %s\n' "$RT_PROFILE"
    printf '  Sync:        none\n'
  fi
  printf '\n'
}

_status_all() {
  local found=false
  local state_base="${RT_HOME}/.rt"

  printf '\n'
  if [[ -d "$state_base" ]]; then
    for pdir in "$state_base"/*/; do
      [[ -d "$pdir" ]] || continue
      found=true
      local pname
      pname=$(basename "$pdir")
      local host="" local_dir="" rdir=""
      [[ -f "$pdir/host" ]]       && host=$(cat "$pdir/host")
      [[ -f "$pdir/local_dir" ]]  && local_dir=$(cat "$pdir/local_dir")
      [[ -f "$pdir/remote_dir" ]] && rdir=$(cat "$pdir/remote_dir")

      local sync_state
      sync_state=$(_sync_status "$pname")

      printf '  [%s] sync=%s — %s:%s ⇄ %s\n' "$pname" "$sync_state" "$host" "$rdir" "$local_dir"
    done
  fi

  if [[ "$found" == false ]]; then
    printf '  No profiles connected.\n'
  fi
  printf '\n'
}

# ── Sync subcommand (Mutagen passthroughs) ────────────────────────
cmd_sync() {
  load_config
  _mutagen_check

  local sub="${1:-}"
  shift || true

  case "$sub" in
    flush)
      if ! _has_sync; then
        die "[$RT_PROFILE] No active sync session. Run 'rt connect' first."
      fi
      if _sync_flush; then
        info "[$RT_PROFILE] Sync flushed."
      else
        warn "[$RT_PROFILE] Flush had issues. Check 'rt sync status'."
      fi
      ;;
    status)
      info "[$RT_PROFILE] Sync state: $(_sync_status)"
      mutagen sync list --label-selector "rt-profile=${RT_PROFILE}" 2>&1 || true
      ;;
    "")
      die "Usage: rt sync <flush|status>"
      ;;
    *)
      die "Unknown sync subcommand: $sub"
      ;;
  esac
}

# ── Slurm subcommand (opt-in via SLURM_ENABLED=1) ─────────────────
cmd_slurm() {
  load_config
  _slurm_require_enabled

  local sub="${1:-}"
  shift || true

  case "$sub" in
    submit) _slurm_submit "$@" ;;
    queue)  _slurm_queue  "$@" ;;
    cancel) _slurm_cancel "$@" ;;
    logs)   _slurm_logs   "$@" ;;
    "")     die "Usage: rt slurm <submit|queue|cancel|logs> ..." ;;
    *)      die "Unknown slurm subcommand: $sub" ;;
  esac
}

_slurm_require_enabled() {
  [[ "${SLURM_ENABLED:-0}" == "1" ]] \
    || die "Slurm is not enabled for profile '${RT_PROFILE}'. Set SLURM_ENABLED=1 in $RT_CONF."
}

_slurm_submit() {
  local script=""
  local sbatch_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --) shift; sbatch_args+=("$@"); break ;;
      -*) die "Use '-- ...' to pass flags to sbatch. Got: $1" ;;
      *)  if [[ -z "$script" ]]; then script="$1"; else sbatch_args+=("$1"); fi; shift ;;
    esac
  done
  [[ -n "$script" ]] || die "Usage: rt slurm submit <script> [-- sbatch_args...]"

  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST."

  # Mandatory flush — script must be on remote before sbatch
  if _has_sync; then
    info "[$RT_PROFILE] Flushing sync before submit ..."
    _sync_flush || die "Sync flush failed; aborting submit to avoid stale code."
  else
    warn "[$RT_PROFILE] No active sync session. Submitting anyway — assuming script is already on remote."
  fi

  info "[$RT_PROFILE] sbatch ${sbatch_args[*]:-} ${script}"
  local output
  if ! output=$(_ssh "cd '${REMOTE_DIR}' && sbatch ${sbatch_args[*]:-} '${script}'" 2>&1); then
    printf '%s\n' "$output" >&2
    die "sbatch failed."
  fi
  printf '%s\n' "$output"

  local jobid
  jobid=$(echo "$output" | sed -n 's/.*Submitted batch job \([0-9][0-9]*\).*/\1/p')
  if [[ -n "$jobid" ]]; then
    mkdir -p "$RT_STATE_DIR"
    {
      [[ -f "$RT_STATE_DIR/slurm_jobs" ]] && cat "$RT_STATE_DIR/slurm_jobs"
      printf '%s:%s:%s\n' "$jobid" "$(date +%s)" "$script"
    } | tail -50 > "$RT_STATE_DIR/slurm_jobs.tmp"
    mv "$RT_STATE_DIR/slurm_jobs.tmp" "$RT_STATE_DIR/slurm_jobs"
    info "Job $jobid recorded. Logs: rt -p $RT_PROFILE slurm logs $jobid"
  fi
}

_slurm_queue() {
  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST."
  local fmt='%.10i %.12P %.20j %.8T %.10M %R'
  if [[ "${1:-}" == "--all" || "${1:-}" == "-a" ]]; then
    _ssh "squeue --format='$fmt'"
  else
    _ssh "squeue -u \$USER --format='$fmt'"
  fi
}

_slurm_cancel() {
  [[ $# -gt 0 ]] || die "Usage: rt slurm cancel <jobid> [<jobid>...]"
  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST."
  _ssh "scancel $*"
}

_slurm_logs() {
  local jobid=""
  local follow=false
  local err=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--follow) follow=true; shift ;;
      --err)       err=true; shift ;;
      -*)          die "Unknown flag: $1" ;;
      *)           jobid="$1"; shift ;;
    esac
  done

  if [[ -z "$jobid" ]]; then
    if [[ -f "$RT_STATE_DIR/slurm_jobs" ]]; then
      info "[$RT_PROFILE] Recent submissions (newest first):"
      printf '\n'
      awk -F: '{a[NR]=$0} END{for(i=NR;i>=1 && i>NR-10;i--) print a[i]}' "$RT_STATE_DIR/slurm_jobs" \
      | while IFS=: read -r id ts script; do
          local when="?"
          if [[ "$RT_OS" == "Darwin" ]]; then
            when=$(date -r "$ts" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "?")
          else
            when=$(date -d "@$ts" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "?")
          fi
          printf '  %-12s  %s  %s\n' "$id" "$when" "$script"
        done
      printf '\n'
    else
      info "No submissions recorded for profile '$RT_PROFILE'. Try: rt slurm queue"
    fi
    return 0
  fi

  _ssh_test || die "[$RT_PROFILE] Cannot reach $REMOTE_HOST."

  local ext=".out"
  $err && ext=".err"
  local primary="${SLURM_LOG_DIR}/slurm-${jobid}${ext}"
  local fallback="${REMOTE_DIR}/slurm-${jobid}${ext}"
  local path=""

  if _ssh "test -f '${primary}'"; then
    path="$primary"
  elif [[ "$primary" != "$fallback" ]] && _ssh "test -f '${fallback}'"; then
    path="$fallback"
  else
    die "Log not found: ${primary}$([[ "$primary" != "$fallback" ]] && echo " (also tried ${fallback})")"
  fi

  if $follow; then
    _ssh "tail -f '${path}'"
  else
    _ssh "cat '${path}'"
  fi
}

cmd_help() {
  cat <<HELP
Remote Toolkit — Drive remote servers from Claude Code

USAGE:
  rt [--profile NAME] <command> [options]
  rt [-p NAME] <command> [options]

GLOBAL FLAGS:
  -p, --profile NAME   Select a profile (default: "default")
                        Config file: rt.conf (default) or rt.conf.<NAME>
                        Local replica: ~/work (default) or ~/work/<NAME>

COMMANDS:
  init                 Create config directory and default config
  check                Check local dependencies, report what's missing
  setup-key            Copy SSH key to remote (one-time, password auth)
  setup-key --password PASS
                       Non-interactive key push (requires sshpass)
  connect              Start Mutagen sync; ensures daemon is running
  disconnect           Terminate sync; preserves local replica files
  exec <command>       Run a command on the remote (auto-flushes sync)
  exec --no-flush <cmd>
                       Skip sync flush (faster for fast iteration)
  exec --bg [--name N] <cmd>
                       Run in background (tmux), survives disconnection
  logs                 List background jobs for this profile
  logs <job_id>        Show output of a background job
  logs <job_id> -f     Follow (tail -f) a background job's output
  status               Show sync + SSH state for current profile
  status --all         Show all profiles
  sync flush           Force sync to reconcile now
  sync status          Detailed Mutagen sync state for this profile
  slurm submit <script> [-- sbatch_args...]
                       Flush sync, then sbatch (requires SLURM_ENABLED=1)
  slurm queue [--all]  Show queue (default: filtered to remote \$USER)
  slurm cancel <id>... scancel one or more job IDs
  slurm logs           List recent submissions for this profile
  slurm logs <id> [-f] [--err]
                       Cat or tail slurm-<id>.out (--err for .err)
  help                 Show this help

EXAMPLES:
  # First-time setup
  rt init                                # Create config skeleton
  # Edit \$RT_HOME/rt.conf with REMOTE_HOST, REMOTE_DIR
  rt setup-key --password 'mypass'       # Push SSH key
  rt connect                             # Start sync
  rt exec "ls -la"
  rt disconnect

  # Multiple servers via profiles
  rt -p hpc setup-key --password 'pass'
  rt -p hpc connect
  rt -p hpc exec "nvidia-smi"
  rt status --all

  # HPC / Slurm workflow (set SLURM_ENABLED=1 in rt.conf.<profile>)
  rt -p hpc slurm submit train.sbatch
  rt -p hpc slurm queue
  rt -p hpc slurm logs <jobid> -f
  rt -p hpc slurm cancel <jobid>

ENVIRONMENT:
  RT_HOME              Config & state directory (default: $RT_HOME)

CONFIG FILES (in \$RT_HOME):
  rt.conf              Default profile config
  rt.conf.<NAME>       Named profile config (e.g., rt.conf.hpc)

  Required:
    REMOTE_HOST        user@hostname (or ~/.ssh/config alias)
    REMOTE_DIR         /path/on/remote

  Optional:
    LOCAL_DIR          local replica (default: ~/work or ~/work/<NAME>)
    SSH_KEY            SSH key path (default: agent)
    SSH_PORT           SSH port (default: 22)
    MUTAGEN_SYNC_MODE  default: two-way-resolved
    MUTAGEN_IGNORE_VCS 1 = pass --ignore-vcs (default), 0 = sync .git
    MUTAGEN_IGNORE     bash array of extra ignore patterns
    SLURM_ENABLED      1 enables \`rt slurm *\` (default 0)
    SLURM_LOG_DIR      where slurm-<id>.out lands (default: \$REMOTE_DIR)

NOTE: For non-default SSH_PORT or SSH_KEY, also add a Host entry to
~/.ssh/config so Mutagen sync uses the same parameters.
HELP
}

# ── Main dispatch ──────────────────────────────────────────────────
main() {
  # Parse global --profile / -p flag before subcommand
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p|--profile) RT_PROFILE="$2"; shift 2 ;;
      --profile=*)  RT_PROFILE="${1#--profile=}"; shift ;;
      *)            break ;;
    esac
  done

  _init_profile

  local subcmd="${1:-help}"
  shift || true

  case "$subcmd" in
    init)          cmd_init "$@" ;;
    check)         cmd_check "$@" ;;
    setup-key)     cmd_setup_key "$@" ;;
    connect)       cmd_connect "$@" ;;
    disconnect)    cmd_disconnect "$@" ;;
    exec)          cmd_exec "$@" ;;
    status)        cmd_status "$@" ;;
    logs)          cmd_logs "$@" ;;
    sync)          cmd_sync "$@" ;;
    slurm)         cmd_slurm "$@" ;;
    help|--help|-h) cmd_help ;;
    *)             die "Unknown command: $subcmd. Run 'rt help' for usage." ;;
  esac
}

main "$@"
